# Database
DATABASE_URL=postgresql+asyncpg://ers_user:password@localhost:5432/emergency_rs

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Object Storage (MinIO / Alibaba OSS)
OSS_ENDPOINT=localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=emergency-rs-imagery

# Model
CHANGE_DETECTION_MODEL_PATH=/models/changeformer.pth
SEGMENTATION_MODEL_PATH=/models/segformer.pth
MODEL_DEVICE=cpu

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
